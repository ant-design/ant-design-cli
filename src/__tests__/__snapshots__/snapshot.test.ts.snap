exports[`changelog > changelog 5.20.0 5.22.0 --format markdown 1`] = `
"API Diff: 5.20.0 → 5.22.0

  Button:
    + color: \`default\` \\
    + variant: \`outlined\` \\
    ~ htmlType: string → \`submit\` \\

  Calendar:
    - dateCellRender: function(date: Dayjs): ReactNode
    - monthCellRender: function(date: Dayjs): ReactNode
    - monthFullCellRender: function(date: Dayjs): ReactNode
    ~ cellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\
    ~ fullCellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\

  Cascader:
    + prefix: ReactNode
    ~ notFoundContent: string → ReactNode

  Checkbox:
    + onBlur: function()
    + onFocus: function()

  Collapse:
    + classNames: [\`Record<header \\
    + children: ReactNode
    + label: ReactNode
    + styles: [\`Record<header \\
    ~ items: [ItemType](https://github.com/react-component/collapse/blob/27250ca5415faab16db412b9bff2c131bb4f32fc/src/interface.ts#L6) → [ItemType](#itemtype)

  ColorPicker:
    + disabledFormat: boolean
    ~ mode: \`('single' \\ → \`'single' \\

  ConfigProvider:
    + splitter: { className?: string, style?: React.CSSProperties }

  DatePicker:
    + prefix: ReactNode
    ~ disabledDate: (currentDate: dayjs, info: { from?: dayjs }) => boolean → (currentDate: dayjs, info: { from?: dayjs, type: Picker }) => boolean

  FloatButton:
    + htmlType: \`submit\` \\
    + placement: \`top\` \\

  Input:
    + bordered: boolean
    + onInput: (value: string[]) => void

  Pagination:
    ~ pageSizeOptions: string\\[] \\ → number\\[]
    ~ showSizeChanger: boolean → boolean \\

  Radio:
    + block: boolean

  Segmented:
    + vertical: boolean

  Select:
    + prefix: ReactNode

  Table:
    + filterDropdownProps: [DropdownProps](/components/dropdown#api)
    + minWidth: number
    - filterDropdownOpen: boolean
    - onFilterDropdownOpenChange: function(visible) {}
    ~ render: function(text, record, index) {} → function(value, record, index) {}
    ~ expandedRowClassName: function(record, index, indent): string → string \\

  Tabs:
    + [DropdownProps](/components/dropdown#api): 

  TimePicker:
    + prefix: ReactNode

  Tooltip:
    - align: object
    - arrow: boolean \\
    - autoAdjustOverflow: boolean
    - color: string
    - defaultOpen: boolean
    - destroyTooltipOnHide: boolean
    - fresh: boolean
    - getPopupContainer: (triggerNode: HTMLElement) => HTMLElement
    - mouseEnterDelay: number
    - mouseLeaveDelay: number
    - overlayClassName: string
    - overlayStyle: object
    - overlayInnerStyle: object
    - placement: string
    - trigger: \`hover\` \\
    - open: boolean
    - zIndex: number
    - onOpenChange: (open: boolean) => void

  TreeSelect:
    + prefix: ReactNode

  Splitter:
    + layout: \`horizontal\` \\
    + onResizeStart: \`(sizes: number[]) => void\`
    + onResize: \`(sizes: number[]) => void\`
    + onResizeEnd: \`(sizes: number[]) => void\`"
`;

