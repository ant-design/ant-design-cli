// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`help > --help 1`] = `
"Usage: antd [options] [command]

CLI tool for querying antd knowledge and analyzing antd usage

Options:
  --format <format>                Output format: json, text, or markdown
                                   (default: "text")
  --version <version>              Target antd version (e.g. 5.20.0)
  --lang <lang>                    Output language: en or zh (default: "en")
  --detail                         Full information output (default: false)
  -V, --cli-version                Output the CLI version number
  -h, --help                       display help for command

Commands:
  list                             List all components with bilingual names,
                                   descriptions, and first-supported version
  info <component>                 Query component API: props, type definitions,
                                   default values
  doc <component>                  Output the full API documentation for a
                                   component in markdown
  demo <component> [name]          Get demo source code for a component
  token [component]                Query Design Tokens (global or
                                   component-level)
  semantic <component>             Query the semantic customization structure of
                                   a component
  changelog [v1] [v2] [component]  Query changelog or compare API differences
                                   between versions
  doctor                           Diagnose project-level antd configuration
                                   issues
  usage [options] [dir]            Scan project for antd component/API usage
                                   statistics
  lint [options] [target]          Check antd usage against best practices
  migrate [options] <from> <to>    Version migration guide with optional
                                   auto-fix
  mcp                              Start MCP (Model Context Protocol) server for
                                   AI assistant integration
  bug [options]                    Report a bug to the antd repository
  bug-cli [options]                Report a bug to the ant-design-cli repository
  help [command]                   display help for command"
`;
