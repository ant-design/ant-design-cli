exports[`changelog > changelog 5.20.0 5.22.0 --format markdown 1`] = `
"API Diff: 5.20.0 → 5.22.0

  Button:
    + color: \`default\` \\
    + variant: \`outlined\` \\
    ~ htmlType: string → \`submit\` \\

  Calendar:
    - dateCellRender: function(date: Dayjs): ReactNode
    - monthCellRender: function(date: Dayjs): ReactNode
    - monthFullCellRender: function(date: Dayjs): ReactNode
    ~ cellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\
    ~ fullCellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\

  Cascader:
    + prefix: ReactNode
    ~ notFoundContent: string → ReactNode

  Checkbox:
    + onBlur: function()
    + onFocus: function()

  Collapse:
    + classNames: [\`Record<header \\
    + children: ReactNode
    + label: ReactNode
    + styles: [\`Record<header \\
    ~ items: [ItemType](https://github.com/react-component/collapse/blob/27250ca5415faab16db412b9bff2c131bb4f32fc/src/interface.ts#L6) → [ItemType](#itemtype)

  ColorPicker:
    + disabledFormat: boolean
    ~ mode: \`('single' \\ → \`'single' \\

  ConfigProvider:
    + splitter: { className?: string, style?: React.CSSProperties }

  DatePicker:
    + prefix: ReactNode
    ~ disabledDate: (currentDate: dayjs, info: { from?: dayjs }) => boolean → (currentDate: dayjs, info: { from?: dayjs, type: Picker }) => boolean

  FloatButton:
    + htmlType: \`submit\` \\
    + placement: \`top\` \\

  Input:
    + bordered: boolean
    + onInput: (value: string[]) => void

  Pagination:
    ~ pageSizeOptions: string\\[] \\ → number\\[]
    ~ showSizeChanger: boolean → boolean \\

  Radio:
    + block: boolean

  Segmented:
    + vertical: boolean

  Select:
    + prefix: ReactNode

  Table:
    + filterDropdownProps: [DropdownProps](/components/dropdown#api)
    + minWidth: number
    - filterDropdownOpen: boolean
    - onFilterDropdownOpenChange: function(visible) {}
    ~ render: function(text, record, index) {} → function(value, record, index) {}
    ~ expandedRowClassName: function(record, index, indent): string → string \\

  Tabs:
    + [DropdownProps](/components/dropdown#api): 

  TimePicker:
    + prefix: ReactNode

  Tooltip:
    - align: object
    - arrow: boolean \\
    - autoAdjustOverflow: boolean
    - color: string
    - defaultOpen: boolean
    - destroyTooltipOnHide: boolean
    - fresh: boolean
    - getPopupContainer: (triggerNode: HTMLElement) => HTMLElement
    - mouseEnterDelay: number
    - mouseLeaveDelay: number
    - overlayClassName: string
    - overlayStyle: object
    - overlayInnerStyle: object
    - placement: string
    - trigger: \`hover\` \\
    - open: boolean
    - zIndex: number
    - onOpenChange: (open: boolean) => void

  TreeSelect:
    + prefix: ReactNode

  Splitter:
    + layout: \`horizontal\` \\
    + onResizeStart: \`(sizes: number[]) => void\`
    + onResize: \`(sizes: number[]) => void\`
    + onResizeEnd: \`(sizes: number[]) => void\`"
`;

exports[`changelog > changelog 5.20.0 5.22.0 --format text 1`] = `
"API Diff: 5.20.0 → 5.22.0

  Button:
    + color: \`default\` \\
    + variant: \`outlined\` \\
    ~ htmlType: string → \`submit\` \\

  Calendar:
    - dateCellRender: function(date: Dayjs): ReactNode
    - monthCellRender: function(date: Dayjs): ReactNode
    - monthFullCellRender: function(date: Dayjs): ReactNode
    ~ cellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\
    ~ fullCellRender: function(current: dayjs, today: dayjs, info: { originNode: React.ReactElement,today: DateType, range?: 'start' \\ → function(current: dayjs, info: { prefixCls: string, originNode: React.ReactElement, today: dayjs, range?: 'start' \\

  Cascader:
    + prefix: ReactNode
    ~ notFoundContent: string → ReactNode

  Checkbox:
    + onBlur: function()
    + onFocus: function()

  Collapse:
    + classNames: [\`Record<header \\
    + children: ReactNode
    + label: ReactNode
    + styles: [\`Record<header \\
    ~ items: [ItemType](https://github.com/react-component/collapse/blob/27250ca5415faab16db412b9bff2c131bb4f32fc/src/interface.ts#L6) → [ItemType](#itemtype)

  ColorPicker:
    + disabledFormat: boolean
    ~ mode: \`('single' \\ → \`'single' \\

  ConfigProvider:
    + splitter: { className?: string, style?: React.CSSProperties }

  DatePicker:
    + prefix: ReactNode
    ~ disabledDate: (currentDate: dayjs, info: { from?: dayjs }) => boolean → (currentDate: dayjs, info: { from?: dayjs, type: Picker }) => boolean

  FloatButton:
    + htmlType: \`submit\` \\
    + placement: \`top\` \\

  Input:
    + bordered: boolean
    + onInput: (value: string[]) => void

  Pagination:
    ~ pageSizeOptions: string\\[] \\ → number\\[]
    ~ showSizeChanger: boolean → boolean \\

  Radio:
    + block: boolean

  Segmented:
    + vertical: boolean

  Select:
    + prefix: ReactNode

  Table:
    + filterDropdownProps: [DropdownProps](/components/dropdown#api)
    + minWidth: number
    - filterDropdownOpen: boolean
    - onFilterDropdownOpenChange: function(visible) {}
    ~ render: function(text, record, index) {} → function(value, record, index) {}
    ~ expandedRowClassName: function(record, index, indent): string → string \\

  Tabs:
    + [DropdownProps](/components/dropdown#api): 

  TimePicker:
    + prefix: ReactNode

  Tooltip:
    - align: object
    - arrow: boolean \\
    - autoAdjustOverflow: boolean
    - color: string
    - defaultOpen: boolean
    - destroyTooltipOnHide: boolean
    - fresh: boolean
    - getPopupContainer: (triggerNode: HTMLElement) => HTMLElement
    - mouseEnterDelay: number
    - mouseLeaveDelay: number
    - overlayClassName: string
    - overlayStyle: object
    - overlayInnerStyle: object
    - placement: string
    - trigger: \`hover\` \\
    - open: boolean
    - zIndex: number
    - onOpenChange: (open: boolean) => void

  TreeSelect:
    + prefix: ReactNode

  Splitter:
    + layout: \`horizontal\` \\
    + onResizeStart: \`(sizes: number[]) => void\`
    + onResize: \`(sizes: number[]) => void\`
    + onResizeEnd: \`(sizes: number[]) => void\`"
`;

exports[`changelog > changelog 5.20.0..5.22.0 --format json 1`] = `
"[
  {
    "version": "5.22.0",
    "date": "2024-11-12",
    "changes": [
      {
        "component": "Form",
        "type": "feature",
        "description": "- 🆕 Form.Item supports hiding labels. [](https://github.com/crazyair)"
      },
      {
        "component": "Form",
        "type": "fix",
        "description": "- 🐞 Form removes the div used to expand the error height, wraps errorDom and extraDom with a div, and sets a minimum height for the div. [](https://github.com/hongzzz)"
      },
      {
        "component": "Form",
        "type": "fix",
        "description": "- 🐞 Fix the problem that \`onValuesChange\` is still triggered when the Form field triggers change but the value does not change. [](https://github.com/crazyair)"
      },
      {
        "component": "Form",
        "type": "feature",
        "description": "- 🆕 Form supports the focus property in scrollToFirstError when form validation fails. [](https://github.com/nathanlao)"
      },
      {
        "component": "Table",
        "type": "feature",
        "description": "- 🆕 Table column filter drop-down box supports \`filterDropdownProps\`. [](https://github.com/Wxh16144)"
      },
      {
        "component": "Table",
        "type": "feature",
        "description": "- 🆕 Table \`expandedRowClassName\` supports string . [-jia-nan](https://github.com/li-jia-nan)"
      },
      {
        "component": "Tree",
        "type": "style",
        "description": "- 💄 Fix the problem of missing padding style for selected nodes in Tree. [](https://github.com/zombieJ)"
      },
      {
        "component": "Tree",
        "type": "feature",
        "description": "- 🆕 Tree component Token adds \`nodeHoverColor\` and \`nodeSelectedColor\` support. [](https://github.com/zmbxy)"
      },
      {
        "component": "Tree",
        "type": "feature",
        "description": "- 🆕 Tree adds \`indentSize\` token for custom indent width. [](https://github.com/afc163)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "- 🆕 DatePicker supports prefix attribute. [](https://github.com/guoyunhe)"
      },
      {
        "component": "DatePicker",
        "type": "style",
        "description": "- 💄 Fixed the issue of DatePicker.RangePicker flashing when the mouse moves between cells. [](https://github.com/afc163)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "- 🆕 In the \`Input.OTP\` component, add \`onInput\` event to get the value of each user input. At the same time, the relevant documentation has been updated. [](https://github.com/aojunhao123)"
      },
      {
        "component": "DatePicker",
        "type": "fix",
        "description": "- 🐞 Fixed the problem that Input.OTP cannot specify \`inputMode\`. [-rudzinski](https://github.com/alan-rudzinski)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "🆕 ColorPicker supports \`disabledFormat\`. [-muzhi](https://github.com/su-muzhi)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "🆕 Add \`cursor\` configuration item to the \`focus\` method of InputNumber component to control the cursor position. [](https://github.com/aojunhao123)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "🆕 Cascader adds \`disabled\` attribute to disable all first-level directory items of the component. [](https://github.com/aojunhao123)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "🆕 Descriptions supports single-line spreading. [](https://github.com/crazyair)"
      },
      {
        "component": "DatePicker",
        "type": "feature",
        "description": "🆕 Select/TreeSelect/Cascader components add \`prefix\` property to support custom prefix. [](https://github.com/guoyunhe)"
      },
      {
        "component": "DatePicker",
        "type": "fix",
        "description": "🐞 Fix the problem that the preview image class name is lost when setting \`ImageProps.preview.rootClassName\` in Image. [](https://github.com/dislido)"
      },
      {
        "component": "DatePicker",
        "type": "fix",
        "description": "🐞 Fixed the issue that the last item in the TimePicker panel column cannot be scrolled to the top. [](https://github.com/zombieJ)"
      },
      {
        "component": "DatePicker",
        "type": "fix",
        "description": "🐞 Fix TreeSelect dropdown height not enough. [](https://github.com/afc163)"
      },
      {
        "component": "DatePicker",
        "type": "fix",
