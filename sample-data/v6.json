{
  "version": "6.0.0",
  "majorVersion": "v6",
  "components": [
    {
      "name": "Button",
      "category": "General",
      "categoryZh": "通用",
      "description": "To trigger an operation.",
      "descriptionZh": "按钮用于开始一个即时操作。",
      "whenToUse": "A button means an operation (or a series of operations). Clicking a button will trigger corresponding business logic.",
      "whenToUseZh": "标记了一个（或封装一组）操作命令，响应用户点击行为，触发相应的业务逻辑。",
      "props": [
        { "name": "block", "type": "boolean", "default": "false", "description": "Option to fit button width to its parent width", "since": "1.0.0" },
        { "name": "classNames", "type": "Record<SemanticDOM, string>", "default": "-", "description": "Semantic DOM class", "since": "5.4.0" },
        { "name": "color", "type": "default | primary | danger", "default": "default", "description": "Set button color", "since": "5.21.0" },
        { "name": "disabled", "type": "boolean", "default": "false", "description": "Disabled state of button", "since": "1.0.0" },
        { "name": "href", "type": "string", "default": "-", "description": "Redirect url of link button", "since": "1.0.0" },
        { "name": "htmlType", "type": "submit | reset | button", "default": "button", "description": "Set the original html type of button", "since": "1.0.0" },
        { "name": "icon", "type": "ReactNode", "default": "-", "description": "Set the icon component of button", "since": "1.0.0" },
        { "name": "iconPosition", "type": "start | end", "default": "start", "description": "Set the icon position of button", "since": "5.17.0" },
        { "name": "loading", "type": "boolean | { delay: number }", "default": "false", "description": "Set the loading status of button", "since": "1.0.0" },
        { "name": "shape", "type": "default | circle | round", "default": "default", "description": "Can be set button shape", "since": "1.0.0" },
        { "name": "size", "type": "large | middle | small", "default": "middle", "description": "Set the size of button", "since": "1.0.0" },
        { "name": "styles", "type": "Record<SemanticDOM, CSSProperties>", "default": "-", "description": "Semantic DOM style", "since": "5.4.0" },
        { "name": "target", "type": "string", "default": "-", "description": "Same as target attribute of a, works when href is specified", "since": "1.0.0" },
        { "name": "variant", "type": "outlined | dashed | solid | filled | text | link", "default": "-", "description": "Set button variant", "since": "5.21.0" },
        { "name": "onClick", "type": "(event: React.MouseEvent) => void", "default": "-", "description": "Set the handler to handle click event", "since": "1.0.0" }
      ],
      "demos": [
        {
          "name": "basic",
          "title": "Basic Usage",
          "description": "Use `color` and `variant` to control button style.",
          "code": "import React from 'react';\nimport { Button, Flex } from 'antd';\n\nconst App: React.FC = () => (\n  <Flex gap=\"small\" wrap>\n    <Button color=\"primary\" variant=\"solid\">Primary Solid</Button>\n    <Button color=\"primary\" variant=\"outlined\">Primary Outlined</Button>\n    <Button color=\"danger\" variant=\"solid\">Danger Solid</Button>\n    <Button variant=\"text\">Text Button</Button>\n    <Button variant=\"link\">Link Button</Button>\n  </Flex>\n);\n\nexport default App;"
        }
      ],
      "tokens": [
        { "name": "borderColorDisabled", "type": "string", "default": "#d9d9d9", "description": "Border color of disabled button" },
        { "name": "contentFontSize", "type": "number", "default": "14", "description": "Font size of button content" },
        { "name": "defaultBg", "type": "string", "default": "#ffffff", "description": "Default button background color" },
        { "name": "defaultBorderColor", "type": "string", "default": "#d9d9d9", "description": "Default button border color" },
        { "name": "defaultColor", "type": "string", "default": "rgba(0,0,0,0.88)", "description": "Default button text color" }
      ],
      "semanticStructure": [
        { "key": "icon", "description": "Icon element" }
      ],
      "related": ["Button.Group", "Dropdown.Button"],
      "faq": [],
      "subComponents": ["Button.Group"]
