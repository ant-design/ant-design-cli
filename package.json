{
  "name": "@ant-design/cli",
  "version": "0.1.0",
  "description": "CLI tool for querying antd knowledge and analyzing antd usage in projects",
  "type": "module",
  "bin": {
    "antd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "extract": "tsx scripts/extract.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ant-design",
    "antd",
    "cli",
    "component",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ant-design/ant-design-cli"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "gray-matter": "^4.0.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
